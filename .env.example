# ─── Django ───────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=ecclesia.settings.dev
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Banco de dados (Supabase Session Pooler) ─────────────
# Pegue em: Supabase > Project Settings > Database > Connection string > Session pooler
# Formato: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# ─── Supabase Auth ────────────────────────────────────────
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# JWT Secret: Supabase > Project Settings > API > JWT Settings > JWT Secret (HS256)
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters
SUPABASE_JWT_AUDIENCE=authenticated

# ─── Celery / Redis ───────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── Integrações (fases futuras) ──────────────────────────
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
ASAAS_API_KEY=
OPENAI_API_KEY=
